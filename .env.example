# Copy this file to understand available variables.
# Vite loads env files by mode — see README for dev / uat / prod.

# App environment label (shown in dev/uat banners if needed)
VITE_APP_ENV=development

# Public site URL (used for meta tags, OG links, canonical URLs)
VITE_SITE_URL=http://localhost:3000

# Optional API / CMS endpoint (contact form, headless CMS, etc.)
VITE_API_URL=

# Optional custom contact form endpoint (Formspree, FormSubmit, etc.)
# Leave empty to use FormSubmit with the email in site config
VITE_CONTACT_FORM_ENDPOINT=
